# =============================================================
# Soustružník DB – Firebase konfigurace
# =============================================================
# 1. Zkopírujte tento soubor do .env.local  (cp .env.example .env.local)
# 2. Vyplňte hodnoty z Firebase Console:
#    https://console.firebase.google.com → váš projekt
#    → Nastavení projektu (ozubené kolo) → Obecné → Vaše aplikace → SDK setup
# 3. .env.local NIKDY nekomerčiujte do gitu (je v .gitignore)
#
# Pro Netlify deploy nastavte tyto proměnné v:
#    Site settings → Environment variables
# =============================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
